{
    "data": {
        "batch_size": 64,
        "embeddings": null,
        "features": [
            "pitch_mean_log",
            "pitch_range_log",
            "intensity_mean_vcd",
            "jitter",
            "shimmer",
            "nhr_vcd",
            "rate"
        ],
        "normalization": "zscore_conv_speaker",
        "primary_speaker_selection": "first",
        "zero_pad": true
    },
    "model": {
        "ar_train": false,
        "ar_val": false,
        "att_emb_in": false,
        "att_mask_strategy": "both",
        "att_spk_in": false,
        "dec_emb_in": false,
        "dec_h_dim": 32,
        "dec_layers": 2,
        "dec_spk_in": false,
        "emb_dim": 768,
        "emb_proj": false,
        "emb_proj_dim": 128,
        "emb_style": null,
        "enc_emb_in": false,
        "enc_h_dim": 32,
        "enc_layers": 2,
        "enc_spk_in": false,
        "feature_names": [
            "pitch_mean_log",
            "pitch_range_log",
            "intensity_mean_vcd",
            "jitter",
            "shimmer",
            "nhr_vcd",
            "rate"
        ],
        "lin_emb_in": false,
        "lin_h_dim": 32,
        "lin_layers": 2,
        "train_primary_speaker_only": false
    },
    "optimizer": {
        "class_path": "Adam",
        "init_args": {
            "lr": 0.001
        }
    },
    "trainer": {
        "callbacks": [
            {
                "class_path": "lightning.pytorch.callbacks.LearningRateMonitor"
            },
            {
                "class_path": "lightning.pytorch.callbacks.EarlyStopping",
                "init_args": {
                    "mode": "min",
                    "monitor": "validation_loss",
                    "patience": 25
                }
            },
            {
                "class_path": "lightning.pytorch.callbacks.ModelCheckpoint",
                "init_args": {
                    "filename": "checkpoint-{epoch}-{validation_loss:.5f}",
                    "mode": "min",
                    "monitor": "validation_loss",
                    "save_top_k": 1
                }
            },
            {
                "class_path": "lightning.pytorch.callbacks.ModelCheckpoint",
                "init_args": {
                    "save_last": true
                }
            }
        ],
        "logger": {
            "class_path": "lightning.pytorch.loggers.TensorBoardLogger",
            "init_args": {
                "default_hp_metric": false,
                "name": "baseline",
                "save_dir": "lightning_logs"
            }
        },
        "precision": "16-mixed"
    }
}